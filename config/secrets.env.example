# Secrets Configuration
# Rename this file to secrets.env and fill in your API keys.
# This file is ignored by git to protect your secrets.
#
# Live paper trading WITH LLM (see config/settings.yaml ai.enabled + provider_chain):
#   Set OPENROUTER_API_KEY from https://openrouter.ai/keys — required for OpenRouter in provider_chain.

# Your private key for signing Polymarket CLOB orders (Polygon). Use either name:
# IMPORTANT: This is a highly sensitive key. Do not share it.
PRIVATE_KEY=""
# Alternative env name (supported by bot + preflight):
# POLYMARKET_PRIVATE_KEY=""

# Polymarket CLOB API (required when trading.dry_run is false — create in Polymarket builder docs)
# POLYMARKET_API_KEY=""
# POLYMARKET_API_SECRET=""
# POLYMARKET_API_PASSPHRASE=""

# API key for Etherscan to fetch contract ABIs and other chain data
ETHERSCAN_API_KEY=""

# API keys for AI analysis providers
# You only need to provide keys for the providers you intend to use.
OPENAI_API_KEY=""
# OpenRouter (OpenAI-compatible API); use with ai.provider_chain type: openai + base_url https://openrouter.ai/api/v1
OPENROUTER_API_KEY=""
ANTHROPIC_API_KEY=""
GROQ_API_KEY=""
GOOGLE_API_KEY=""
